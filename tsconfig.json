{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "strict": true,
    "noEmit": true,

    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}